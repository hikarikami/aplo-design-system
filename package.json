{
  "name": "aplo-design-system",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm build:ui && pnpm build:docs",
    "build:ui": "pnpm --filter @aplo/ui build",
    "build:docs": "pnpm --filter aplo-docs build",
    "preview": "pnpm --filter aplo-docs preview",
    "gen:props": "pnpm build:ui && node scripts/generate-props.mjs"
  },
  "devDependencies": {
    "typescript": "~5.6.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
