{
  "_meta": {
    "source": "packages/ui/src/styles/theme.css",
    "inferred": false,
    "notes": "Tokens extracted directly from CSS custom properties and Tailwind utilities in theme.css"
  },

  "color": {
    "_notes": "All values are CSS custom properties resolved at runtime. Light mode defaults shown.",
    "background": "hsl(0 0% 98%)",
    "foreground": "hsl(240 5% 10%)",
    "card": "hsl(0 0% 100%)",
    "card-foreground": "hsl(240 5% 10%)",
    "primary": "hsl(179 100% 21%)",
    "primary-hex": "#006B69",
    "primary-foreground": "hsl(0 0% 100%)",
    "secondary": "hsl(240 5% 92%)",
    "secondary-foreground": "hsl(240 5% 10%)",
    "muted": "hsl(240 5% 94%)",
    "muted-foreground": "hsl(240 4% 46%)",
    "destructive": "hsl(0 84% 60%)",
    "destructive-foreground": "hsl(0 0% 100%)",
    "border": "hsl(240 5% 88%)",
    "input": "hsl(240 5% 88%)",
    "ring": "hsl(179 100% 21%)",
    "accent": "hsl(183 40% 90%)",
    "accent-foreground": "hsl(183 40% 15%)",
    "popover": "hsl(0 0% 100%)",
    "popover-foreground": "hsl(240 5% 10%)",

    "aplo": {
      "_notes": "Dark surface scale. aplo-900 is the default dark background.",
      "100": "hsl(179 80% 88%)",
      "200": "hsl(179 70% 74%)",
      "300": "hsl(179 65% 55%)",
      "400": "hsl(179 60% 42%)",
      "500": "#3a3a46",
      "600": "#2e2e37",
      "700": "#25252c",
      "800": "#1d1d22",
      "900": "#161619",
      "accent": "#006b69",
      "accent-hover": "#135252"
    },

    "dark-overrides": {
      "_notes": "Applied when .dark class is on <html>",
      "background": "hsl(240 5% 9%)",
      "foreground": "hsl(0 0% 96%)",
      "card": "hsl(240 5% 12%)",
      "secondary": "hsl(240 5% 18%)",
      "muted": "hsl(240 5% 16%)",
      "accent": "hsl(183 40% 18%)",
      "border": "hsl(240 5% 20%)",
      "input": "hsl(240 5% 20%)",
      "ring": "hsl(179 65% 55%)"
    },

    "ripple": {
      "_notes": "RGB values used for canvas ripple particles",
      "light": "0,107,105",
      "dark": "55,190,183"
    }
  },

  "radius": {
    "sm": "2px",
    "md": "4px",
    "lg": "6px",
    "full": "9999px",
    "_notes": "md = rounded-md (inputs/buttons), lg = rounded-lg (cards/panels), full = rounded-full (switch, radio, avatars)"
  },

  "spacing": {
    "_notes": "Tailwind default spacing scale. Key values used in components:",
    "gap-2": "8px",
    "gap-3": "12px",
    "gap-4": "16px",
    "gap-6": "24px",
    "px-6": "24px",
    "py-8": "32px",
    "space-y-1.5": "6px",
    "space-y-4": "16px",
    "space-y-6": "24px"
  },

  "sizing": {
    "navbar-height": "56px",
    "sidebar-open": "256px",
    "sidebar-closed": "40px",
    "container-max-width": "77.5rem",
    "button-sm": "32px height, 12px px",
    "button-default": "40px height, 20px px",
    "button-lg": "48px height, 28px px",
    "button-xl": "56px height, 36px px",
    "input-sm": "36px height",
    "input-default": "40px height",
    "input-lg": "48px height",
    "icon-default": "16px",
    "icon-md": "20px",
    "icon-lg": "24px"
  },

  "typography": {
    "font-family": "\"Lato\", ui-sans-serif, system-ui, sans-serif",
    "weights": [400, 700, 900],
    "scale": {
      "xs": "12px",
      "sm": "14px",
      "base": "16px",
      "lg": "18px",
      "xl": "20px",
      "2xl": "24px",
      "4xl": "36px"
    },
    "patterns": {
      "page-title": "text-4xl font-bold tracking-tight",
      "section-heading": "text-lg font-semibold",
      "card-heading": "text-sm font-semibold",
      "body": "text-sm",
      "meta": "text-xs text-muted-foreground",
      "eyebrow": "text-xs font-semibold uppercase tracking-widest text-muted-foreground",
      "label": "text-sm font-medium text-foreground",
      "link": "text-primary dark:text-aplo-300 underline-offset-4 hover:underline"
    }
  },

  "shadow": {
    "focus-ring": "0 0 0 3px hsl(179 100% 21% / 0.12)",
    "popup": "shadow-md (Tailwind)",
    "thumb": "shadow-sm (Tailwind)",
    "_notes": "Focus ring applied to inputs/selects on focus. Popup shadow on Select dropdown only."
  },

  "animation": {
    "fade-in": "opacity 0 → 1, translateY 4px → 0, duration 300ms ease-out",
    "march": "stroke-dashoffset 16 → 0, 1s linear infinite (marching ants border on FileUpload)",
    "ripple": "canvas-based particle wave, duration ~600ms, motion-gated",
    "stipple-fade": "canvas-based particle fade, duration 2800ms, motion-gated",
    "durations": {
      "fast": "150ms",
      "default": "200ms",
      "slow": "300ms",
      "sidebar": "300ms ease-in-out-expo"
    }
  },

  "zIndex": {
    "navbar": 50,
    "popup": 50,
    "canvas-decorative": -1,
    "_notes": "Navbar and Select popup both use z-50. Canvas globes use z-0 (below relative z-10 content)."
  }
}
